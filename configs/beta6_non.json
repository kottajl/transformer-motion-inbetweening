{
    "config_name": "beta6_non",
    "description": "Beta 0.6 'no pe' model. Just testing what will actually happen without PE.",

    "context_frames": 10,
    "hole_frames": [4, 16],
    "target_frames": 1,

    "batch_size": 512,
    "n_epochs": 512,
    "patience": 8,
    "val_ratio": 0.16,
    "window_step": 4,

    "optimizer_lr": 0.0001,

    "loss_weights": {
        "rot_6d": 0.5,
        "pos": 0.35,
        "fk": 0.1,
        "smoothness": 0.05
    },
    "fk_weighted": false,

    "joint_embedding_size": 48,
    "root_embedding_size": 48,

    "num_encoder_layers": 6,
    "num_decoder_layers": 0,
    "num_heads": 8,
    "dropout": 0.05,

    "velocity_included": true,

    "pe_type": "none",
    "interpolate_before_prediction": true
}