{
    "config_name": "alpha14_7",
    "description": "Alpha 0.14.7 model. It's 0.14.5 but bigger pos loss weight value and smaller rot_6d loss weight value (rot_6d: 0.6 -> 0.5, pos: 0.25 -> 0.35).",

    "context_frames": 10,
    "hole_frames": 10,
    "target_frames": 1,

    "batch_size": 512,
    "n_epochs": 512,
    "patience": 8,
    "val_ratio": 0.16,
    "window_step": 4,

    "optimizer_lr": 0.0001,

    "loss_weights": {
        "rot_6d": 0.5,
        "pos": 0.35,
        "fk": 0.1,
        "smoothness": 0.05
    },
    "fk_weighted": false,

    "joint_embedding_size": 48,
    "root_embedding_size": 48,

    "num_encoder_layers": 6,
    "num_decoder_layers": 2,
    "num_heads": 8,
    "dropout": 0.05,

    "interpolate_before_prediction": true
}