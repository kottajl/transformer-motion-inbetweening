{
    "config_name": "alpha04_batch128",
    "description": "Alpha 0.4 with increased batch size. The same as alpha04 but with batch size of 128 for faster training.",

    "context_frames": 10,
    "hole_frames": 5,
    "target_frames": 5,

    "batch_size": 128,
    "n_epochs": 128,
    "patience": 16,
    "val_ratio": 0.15,
    "window_step": 4,

    "optimizer_lr": 0.0001,

    "loss_weights": {
        "rot_6d": 0.6,
        "pos": 0.3,
        "fk": 0.1
    },

    "joint_embedding_size": 48,
    "root_embedding_size": 48,

    "num_encoder_layers": 4,
    "num_decoder_layers": 2,
    "num_heads": 8,
    "dropout": 0.05,

    "interpolate_before_prediction": true
}