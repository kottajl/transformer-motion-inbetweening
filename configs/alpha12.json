{
    "config_name": "alpha12",
    "description": "Alpha 0.12 model. Decreased weight for smoothness loss and it's now operating on accelerations instead of velocities. Dynamic LR stars from lowe value. Batch size to 512.",

    "context_frames": 10,
    "hole_frames": 10,
    "target_frames": 1,

    "batch_size": 512,
    "n_epochs": 512,
    "patience": 16,
    "val_ratio": 0.16,
    "window_step": 4,

    "optimizer_lr": 0.00005,

    "loss_weights": {
        "rot_6d": 0.65,
        "pos": 0.25,
        "fk": 0.1,
        "smoothness": 0.05
    },
    "fk_weighted": false,

    "joint_embedding_size": 48,
    "root_embedding_size": 48,

    "num_encoder_layers": 6,
    "num_decoder_layers": 2,
    "num_heads": 8,
    "dropout": 0.05,

    "interpolate_before_prediction": true
}