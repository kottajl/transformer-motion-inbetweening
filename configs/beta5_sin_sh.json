{
    "config_name": "beta5_sin_sh",
    "description": "Beta 0.5 'sinusoidal' 'short hole' model. Add velocity (frame difference) mode to the input sequence inside the model. No embedding sizes modified. Sinusoidal PE. Shorter hole size range.",

    "context_frames": 10,
    "hole_frames": [4, 16],
    "target_frames": 1,

    "batch_size": 256,
    "n_epochs": 512,
    "patience": 8,
    "val_ratio": 0.16,
    "window_step": 4,

    "optimizer_lr": 0.0001,

    "loss_weights": {
        "rot_6d": 0.5,
        "pos": 0.35,
        "fk": 0.1,
        "smoothness": 0.05
    },
    "fk_weighted": false,

    "joint_embedding_size": 48,
    "root_embedding_size": 48,

    "num_encoder_layers": 6,
    "num_decoder_layers": 2,
    "num_heads": 8,
    "dropout": 0.05,

    "velocity_included": true,

    "pe_type": "sinusoidal",
    "interpolate_before_prediction": true
}